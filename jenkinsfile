pipeline {
    agent any
    stages {
        stage('CleanUp de Workspace') {
            steps {
                cleanWs()
            }
        }
        stage('Cloner le GitHub') {
            steps {
                git branch: 'main', url: 'https://github.com/ohmanass/depot-OnlineDev26.git'
            }
        }
        stage('install Docker') {
            steps {
                sh '''
                    sudo flock -w 120 /var/lib/dpkg/lock-frontend echo "ok"
                    sudo systemctl stop docker docker.socket || true
                    sudo apt-get remove -y docker.io containerd runc || true
                    sudo apt-get autoremove -y || true
                    sudo rm -rf /var/lib/docker /var/lib/containerd /run/containerd
                    sudo apt-get update -y
                    sudo apt-get install -y containerd runc docker.io
                    sudo systemctl start containerd
                    sudo systemctl start docker
                    sudo chmod 666 /var/run/docker.sock
                    sudo usermod -aG docker jenkins
                '''
            }
        }
        stage('Build image Docker') {
            steps {
                script {
                    sh 'docker image rm -f mynginx || true'
                    sh 'docker build -t mynginx .'
                    sh 'docker image ls'
                }
            }
        }
    }
}